---
// src/layouts/Layout.astro

// MarkdownのFrontmatterからデータを受け取るための魔法の書き方
const { frontmatter } = Astro.props;

// titleをfrontmatterから取得。なければ直接のpropsから取得。
const title = frontmatter?.title || Astro.props.title || "デフォルトタイトル";
---


<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
